{
  "llm": {
    "default": "ollama",
    "openai": {
      "model": "gpt-4",
      "api_key": "",
      "params": { "temperature": 0.2 }
    },
    "anthropic": {
      "model": "claude-3-opus-20240229",
      "api_key": "",
      "params": {}
    },
  "ollama": {
    "model": "qwen2.5:1.5b",
    "base_url": "http://localhost:11434",
    "think": false,
    "timeout": 60,
    "params": { "temperature": 0.2 }
  },
    "local": {
      "model": "Qwen/Qwen2.5-0.5B-Instruct",
      "device": "cpu",
      "quantize_4bit": false,
      "cache_dir": "~/.cache/novahands/models",
      "params": { "temperature": 0.2, "max_new_tokens": 256 }
    }
  },
  "security": {
    "allowed_apps": [
      "notepad.exe",
      "winword.exe",
      "chrome.exe",
      "wechat.exe",
      "Code.exe",
      "explorer.exe",
      "powershell.exe"
    ],
    "sensitive_operations": [
      "send_keys",
      "click_send_button",
      "delete_file"
    ],
    "confirm_timeout": 30,
    "enable_failsafe": true
  },
  "logging": {
    "level": "INFO",
    "file": "novahands.log"
  },
  "rl": {
    "enabled": true,
    "collect_data": true,
    "train_frequency": 86400,
    "lora_rank": 8,
    "learning_rate": 1e-4,
    "exploration_prob": 0.2,
    "skill_evolution_threshold": 0.8
  },
  "skill_dirs": {
    "user": "skills/user",
    "extra": []
  },
  "api": {
    "host": "127.0.0.1",
    "port": 8000,
    "api_key": "novahands-local-dev"
  },
  "mcp": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 3000,
    "tool_prefix": "novahands"
  },
  "replay": {
    "screen_match_threshold": 0.8,
    "default_speed_multiplier": 1.0,
    "auto_save_replay_dir": "replays"
  },
  "world_model": {
    "enabled": true,
    "encoder": {
      "type": "simple",
      "latent_dim": 64,
      "screen_feature_dim": 32,
      "text_embedding_dim": 16,
      "position_embedding_dim": 16,
      "cache_encodings": true
    },
    "dynamics": {
      "hidden_dim": 128,
      "num_ensembles": 5,
      "learning_rate": 1e-4,
      "batch_size": 64,
      "max_epochs": 100,
      "uncertainty_threshold": 0.5
    },
    "reward": {
      "hidden_dim": 64,
      "learning_rate": 1e-4,
      "batch_size": 64,
      "max_epochs": 50
    },
    "planner": {
      "method": "cem",
      "horizon": 10,
      "num_candidates": 100,
      "num_iterations": 5,
      "elite_fraction": 0.2
    },
    "dreamer_rl": {
      "enabled": false,
      "learning_rate": 0.01,
      "discount_factor": 0.99,
      "exploration_rate": 0.1,
      "imagine_ratio": 10.0,
      "imagination_horizon": 10
    },
    "cache_dir": "cache/world_model"
  }
}
